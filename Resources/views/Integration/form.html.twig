<style>
    .mailruauth-notes {
        align-items: flex-start;
    }

    .mailruauth-notes__body {
        display: block;
        min-width: 0;
        width: 100%;
    }

    .mailruauth-notes__label,
    .mailruauth-notes__value {
        display: block;
        width: 100%;
    }

    .mailruauth-notes__label {
        margin: 0 0 6px;
        font-weight: 600;
        line-height: 1.4;
    }

    .mailruauth-notes__instruction {
        margin: 0 0 14px;
        line-height: 1.45;
    }

    .mailruauth-notes__instruction a {
        font-weight: 600;
        text-decoration: underline;
    }

    .mailruauth-notes__value {
        box-sizing: border-box;
        margin: 0;
        padding: 10px 112px 10px 12px;
        background: rgba(255, 255, 255, 0.78);
        border-radius: 4px;
        color: #1f2933;
        line-height: 1.45;
        overflow-wrap: anywhere;
        white-space: normal;
    }

    .mailruauth-notes__copy-row {
        display: block;
        margin: 0 0 16px;
        position: relative;
        width: 100%;
    }

    .mailruauth-notes__copy-row:last-child {
        margin-bottom: 0;
    }

    .mailruauth-notes__copy {
        background: #fff;
        border: 1px solid rgba(31, 41, 51, 0.22);
        border-radius: 4px;
        color: #1f2933;
        cursor: pointer;
        font-size: 12px;
        font-weight: 600;
        line-height: 1.2;
        min-width: 76px;
        padding: 6px 8px;
        position: absolute;
        right: 6px;
        top: 6px;
        white-space: nowrap;
    }

    .mailruauth-notes__copy:hover,
    .mailruauth-notes__copy:focus {
        border-color: rgba(31, 41, 51, 0.45);
        color: #111827;
    }

    .sales-snap-plugin-footer {
        margin-top: 70px;
        color: #4a4a4a;
        font-weight: 500;
    }

    .sales-snap-plugin-footer a {
        color: inherit;
        text-decoration: none;
    }
</style>

<div class="alert alert-info mailruauth-notes">
    <div class="mailruauth-notes__body">
        <p class="mailruauth-notes__instruction">
            {{ 'mautic.integration.mailruauth.notes.instruction.before'|trans }}
            <a href="https://oauth.mail.ru/app" target="_blank" rel="noopener noreferrer">{{ 'mautic.integration.mailruauth.notes.instruction.link'|trans }}</a>
            {{ 'mautic.integration.mailruauth.notes.instruction.after'|trans }}
        </p>
        <p class="mailruauth-notes__label">{{ 'mautic.integration.mailruauth.notes.redirect_uri'|trans }}</p>
        <div class="mailruauth-notes__copy-row">
            <code id="mailruauth-redirect-uri-value" class="mailruauth-notes__value">{{ redirect_uri }}</code>
            <button type="button" class="mailruauth-notes__copy" data-mailruauth-copy="mailruauth-redirect-uri-value" data-copy-label="{{ 'mautic.integration.mailruauth.notes.copy'|trans|e('html_attr') }}" data-copied-label="{{ 'mautic.integration.mailruauth.notes.copied'|trans|e('html_attr') }}">{{ 'mautic.integration.mailruauth.notes.copy'|trans }}</button>
        </div>
        <p class="mailruauth-notes__label">{{ 'mautic.integration.mailruauth.notes.scope'|trans }}</p>
        <div class="mailruauth-notes__copy-row">
            <code id="mailruauth-scope-value" class="mailruauth-notes__value">{{ scope }}</code>
            <button type="button" class="mailruauth-notes__copy" data-mailruauth-copy="mailruauth-scope-value" data-copy-label="{{ 'mautic.integration.mailruauth.notes.copy'|trans|e('html_attr') }}" data-copied-label="{{ 'mautic.integration.mailruauth.notes.copied'|trans|e('html_attr') }}">{{ 'mautic.integration.mailruauth.notes.copy'|trans }}</button>
        </div>
    </div>
</div>

<div class="sales-snap-plugin-footer">
    Copyright 2026 <a href="https://salessnap.ru" target="_blank" rel="noopener noreferrer">Sales Snap</a>. All Rights Reserved.
</div>
<script>
    (function () {
        var buttons = document.querySelectorAll('[data-mailruauth-copy]');

        function fallbackCopy(value) {
            var textarea = document.createElement('textarea');
            textarea.value = value;
            textarea.setAttribute('readonly', 'readonly');
            textarea.style.position = 'fixed';
            textarea.style.left = '-9999px';
            document.body.appendChild(textarea);
            textarea.select();

            try {
                document.execCommand('copy');
            } finally {
                document.body.removeChild(textarea);
            }
        }

        function copyText(value) {
            if (navigator.clipboard && window.isSecureContext) {
                return navigator.clipboard.writeText(value).catch(function () {
                    fallbackCopy(value);
                });
            }

            fallbackCopy(value);

            return Promise.resolve();
        }

        Array.prototype.forEach.call(buttons, function (button) {
            button.addEventListener('click', function () {
                var target = document.getElementById(button.getAttribute('data-mailruauth-copy'));
                var copyLabel = button.getAttribute('data-copy-label') || button.textContent;
                var copiedLabel = button.getAttribute('data-copied-label') || 'Copied';

                if (!target) {
                    return;
                }

                copyText(target.textContent.trim()).then(function () {
                    button.textContent = copiedLabel;
                    window.setTimeout(function () {
                        button.textContent = copyLabel;
                    }, 1200);
                });
            });
        });
    })();
</script>
